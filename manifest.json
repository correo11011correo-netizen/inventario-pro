{
  "id": "com.stockpro.inventario.v1",
  "name": "StockPro: Inventario y Ventas HD",
  "short_name": "StockPro",
  "description": "Sistema profesional de gestión de stock con escáner de alta precisión.",
  "start_url": "./index.html",
  "scope": "./",
  "display": "standalone",
  "display_override": ["tabbed", "window-controls-overlay", "minimal-ui"],
  "orientation": "portrait",
  "background_color": "#0f172a",
  "theme_color": "#6366f1",
  "categories": ["business", "productivity", "utilities", "shopping", "notes"],
  "lang": "es",
  "dir": "ltr",
  "prefer_related_applications": false,
  "related_applications": [
    {
      "platform": "play",
      "id": "com.stockpro.inventario"
    }
  ],
  "iarc_rating_id": "TUCODIGODE_RATING",
  "scope_extensions": [
    { "origin": "https://correo11011correo-netizen.github.io" },
    { "origin": "https://subdominio.tuapp.com" }
  ],
  "shortcuts": [
    {
      "name": "Inventario",
      "url": "./index.html",
      "icons": [
        { "src": "icon-192.png", "sizes": "192x192", "type": "image/png" }
      ]
    }
  ],
  "file_handlers": [
    {
      "action": "./index.html",
      "accept": {
        "application/pdf": [".pdf"]
      }
    }
  ],
  "launch_handler": {
    "client_mode": "focus-existing"
  },
  "protocol_handlers": [
    {
      "protocol": "mailto",
      "url": "./index.html?to=%s"
    }
  ],
  "share_target": {
    "action": "/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "edge_side_panel": {
    "preferred_width": 400
  },
  "icons": [
    { "src": "icon-192.png", "sizes": "192x192", "type": "image/png" },
    { "src": "icon-512.png", "sizes": "512x512", "type": "image/png" },
    { "src": "maskable-icon.png", "sizes": "512x512", "type": "image/png", "purpose": "maskable" }
  ],
  "screenshots": [
    { "src": "icon-512.png", "sizes": "512x512", "type": "image/png", "form_factor": "narrow" },
    { "src": "icon-512.png", "sizes": "512x512", "type": "image/png", "form_factor": "wide" }
  ]
}
